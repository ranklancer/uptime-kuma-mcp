# ─── Uptime Kuma MCP Server Configuration ─────────────────────────
#
# Copy this file to .env and fill in your values.
#
# Multi-instance: list all instance names, comma-separated.
# For each instance, provide <UPPERCASED_NAME>_BASE_URL, _USERNAME, and _PASSWORD.

# Comma-separated instance names (no spaces around commas)
KUMA_INSTANCES=kuma

# ─── Instance: kuma ───────────────────────────────────────────────
KUMA_BASE_URL=http://kuma.example.com:3001
KUMA_USERNAME=admin
KUMA_PASSWORD=your-uptime-kuma-password-here
# Set to "true" if Uptime Kuma uses a self-signed TLS certificate
KUMA_INSECURE_TLS=false

# ─── Instance: secondary (uncomment to enable) ───────────────────
# KUMA_INSTANCES=kuma,secondary
# SECONDARY_BASE_URL=https://kuma2.example.com:3001
# SECONDARY_USERNAME=admin
# SECONDARY_PASSWORD=your-secondary-password-here
# SECONDARY_INSECURE_TLS=true

# ─── Server settings ─────────────────────────────────────────────
HOST=0.0.0.0
PORT=3000
NODE_ENV=production
TZ=UTC
